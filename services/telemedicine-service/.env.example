# ─── Telemedicine Service ────────────────────────────────────────
PORT=5005
MONGO_URI=mongodb://mongo:27017/telemedicine-service

# ─── Internal service-to-service authentication ─────────────────
INTERNAL_SECRET=change_this_internal_secret

# ─── Service URLs (Docker network hostnames) ────────────────────
APPOINTMENT_SERVICE_URL=http://appointment-service:5003

# ─── RabbitMQ ────────────────────────────────────────────────────
RABBITMQ_URL=amqp://hcadmin:hcpassword@rabbitmq:5672

# ─── JaaS / Jitsi (8x8.vc) ─────────────────────────────────────
JAAS_APP_ID=your-jaas-app-id
JAAS_API_KEY_ID=your-jaas-api-key-id
JAAS_PRIVATE_KEY=your-jaas-private-key