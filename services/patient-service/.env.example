PORT=5002
MONGO_URI=mongodb://localhost:27017/patient-service
INTERNAL_SECRET=change_this_internal_secret

# Supabase — use the service-role key (NOT the anon key) so the server can
# interact with the private medical-reports bucket without relying on RLS.
SUPABASE_URL= supabase_url_goes_here
SUPABASE_SERVICE_ROLE_KEY= supabase_service_role_key_goes_here