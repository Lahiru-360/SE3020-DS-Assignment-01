# ─── Patient Service ─────────────────────────────────────────
PORT=5002
MONGO_URI=mongodb://mongo:27017/patient-service

# ─── Internal service-to-service authentication ─────────────
INTERNAL_SECRET=change_this_internal_secret

# ─── Supabase (medical reports storage) ─────────────────────
# Use the service-role key (NOT the anon key) so the server can
# interact with the private medical-reports bucket without RLS.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
