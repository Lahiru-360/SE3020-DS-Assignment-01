# ─── Auth Service ────────────────────────────────────────────
PORT=5007
MONGO_URI=mongodb://mongo:27017/auth-service

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Service URLs (Docker network hostnames) ────────────────
PATIENT_SERVICE_URL=http://patient-service:5002
DOCTOR_SERVICE_URL=http://doctor-service:5001

# ─── Internal service-to-service authentication ─────────────
INTERNAL_SECRET=change_this_internal_secret

# ─── Default admin account (seeded on first startup) ────────
ADMIN_DEFAULT_EMAIL=admin@system.com
ADMIN_DEFAULT_PASSWORD=Admin@123
